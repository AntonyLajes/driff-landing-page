# Base URL of the Driff API that receives the whitelist form.
# Leave empty to POST to the same origin (/api/whitelist).
VITE_API_BASE_URL=

# Mixpanel project token (browser SDK). Leave empty to disable analytics.
VITE_MIXPANEL_TOKEN=
# Set to "true" if your Mixpanel project uses EU data residency.
VITE_MIXPANEL_EU=
